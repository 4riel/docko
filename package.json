{
  "name": "docko-workspace",
  "version": "0.1.0-alpha.12",
  "description": "Workspace-first slot coordination for AI coding agents with a CLI, protocol core, and Claude Code adapter.",
  "author": "4riel",
  "license": "MIT",
  "keywords": [
    "docko",
    "ai",
    "ai-agents",
    "coding-agents",
    "multi-agent",
    "agent-coordination",
    "local-first",
    "workspace-first",
    "workspace-management",
    "developer-tools",
    "slots",
    "persistent-slots",
    "session-management",
    "claude-code",
    "codex",
    "cli"
  ],
  "files": [
    "bin",
    "README.md",
    "LICENSE",
    "packages/cli/bin/**",
    "packages/cli/dist/**",
    "packages/cli/package.json",
    "packages/core/dist/**",
    "packages/core/package.json",
    "packages/adapters/claude-code/dist/**",
    "packages/adapters/claude-code/package.json",
    "packages/adapters/claude-code/templates/**"
  ],
  "bin": {
    "docko": "bin/docko.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/4riel/docko.git"
  },
  "homepage": "https://github.com/4riel/docko#readme",
  "bugs": {
    "url": "https://github.com/4riel/docko/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.7.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build-workspace.mjs",
    "check": "node scripts/build-workspace.mjs && pnpm -r check",
    "prepack": "node scripts/prepare-pack-bundle.mjs",
    "postpack": "node scripts/prepare-pack-bundle.mjs --restore",
    "prepublishOnly": "pnpm check",
    "release:stage": "node scripts/prepare-publish-dir.mjs",
    "release:verify": "pnpm check && node scripts/prepare-publish-dir.mjs && node scripts/check-publish-manifests.mjs .publish/npm && npm pack --dry-run .publish/npm",
    "publish:alpha:dry-run": "pnpm check && node scripts/prepare-publish-dir.mjs && node scripts/check-publish-manifests.mjs .publish/npm && npm publish .publish/npm --tag alpha --dry-run",
    "test": "node scripts/build-workspace.mjs && node scripts/run-node-tests.mjs --test-concurrency=1",
    "test:coverage": "node scripts/build-workspace.mjs && c8 --reporter=text --all --include=\"packages/core/dist/*.js\" --include=\"packages/cli/dist/*.js\" --include=\"packages/adapters/claude-code/dist/*.js\" node scripts/run-node-tests.mjs --test-concurrency=1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "c8": "^11.0.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@docko/adapter-claude-code": "workspace:*",
    "@docko/cli": "workspace:*",
    "@docko/core": "workspace:*"
  },
  "bundleDependencies": [
    "@docko/adapter-claude-code",
    "@docko/cli",
    "@docko/core"
  ]
}
